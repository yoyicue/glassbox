# Copy to .env and fill in local values. Real secrets and device endpoints do
# not belong in git.

# VLM providers, optional. Keep keys empty and GLASSBOX_ENABLE_VLM unset for
# fully offline/no-VLM runs.
#
# Runtime selection uses GLASSBOX_* config:
#   GLASSBOX_ENABLE_VLM=1 enables Layer-3 VLM in glassbox.runtime.
#   GLASSBOX_VLM=moonshot selects the Moonshot Anthropic-compatible client.
#   GLASSBOX_VLM=siliconflow selects the SiliconFlow OpenAI-compatible client.
# Advanced VLM capability flags are all off by default (experimental, billed):
# set-of-mark grounding, OCR-miss reground, cold-start annotation, etc. See the
# `vlm_*` / `*coldstart*` fields in glassbox/config.py for the canonical list.
# VLM_BACKEND/KIMI_BACKEND are accepted by the lower-level make_vlm_client()
# factory and kept here for direct-client compatibility.
# GLASSBOX_ENABLE_VLM=1
# GLASSBOX_VLM=moonshot
MOONSHOT_API_KEY=
SILICONFLOW_API_KEY=
VLM_BACKEND=anthropic
# KIMI_BACKEND=anthropic
# VLM_MODEL=

# Runtime selection.
# GLASSBOX_FRAME_DIR=/path/to/png-frames
# GLASSBOX_NO_HDMI=1
# GLASSBOX_HDMI_INDEX=0
# GLASSBOX_HDMI_FPS=30

# PicoKVM backend.
# GLASSBOX_PICOKVM=1
# GLASSBOX_PICOKVM_BASE_URL=http://picokvm.local
# GLASSBOX_PICOKVM_AUTH_MODE=nopassword
# GLASSBOX_PICOKVM_USERNAME=
# GLASSBOX_PICOKVM_PASSWORD=

# Controlled device metadata.
# GLASSBOX_PHONE_MODEL=iphone_17_pro_max
# GLASSBOX_PROFILE_BUNDLE=com.example.app
# GLASSBOX_PLATFORM=ios               # ios | ipados
# GLASSBOX_LANGUAGE=zh-Hans           # device UI language (e.g. en for English)
# GLASSBOX_REGION=HK                  # device region; affects locale-sensitive labels

# Optional perception, memory, and artifacts.
# GLASSBOX_OCR=vision
# Icon detector: default is the dependency-free, MIT `classical` (OpenCV). The
# `omniparser` backend (YOLO) is more complete on the Home screen but is an
# AGPL-3.0 drop-in plugin (see glassbox/cognition/icon_backends/README.md); only
# enable it where that plugin + `ultralytics torch huggingface_hub` are installed.
# GLASSBOX_ICON_DETECTOR=omniparser
# GLASSBOX_VLM_CACHE_DIR=.cache/vlm
# GLASSBOX_RECORDING_DIR=recordings
# GLASSBOX_COMPUTER_USE_ARTIFACT_DIR=artifacts/computer_use
# GLASSBOX_COMPUTER_USE_TRACE_LEVEL=standard   # artifact detail level
# GLASSBOX_OCR_TIMEOUT=0              # >0 = per-OCR-call watchdog seconds (enable on a live rig that can hang)
# GLASSBOX_ENABLE_MEMORY=1            # persist the UTG across runs (off by default)
# GLASSBOX_MEMORY_DIR=memory
# GLASSBOX_SEMANTIC_PLAN_OPS=back,scroll,tap   # ops run through the verified-failure strategy ladder
# GLASSBOX_AI_SCROLL_PREFER_WHEEL=1   # prefer precise wheel scroll over swipe-fling where supported
